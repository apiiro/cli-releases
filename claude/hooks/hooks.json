{
    "hooks": {
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "apiiro hooks claude prompt-secret-scan"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "apiiro hooks claude enrich-prompt"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "apiiro hooks claude pre-commit-scan"
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "apiiro hooks claude enrich-session"
                    }
                ]
            }
        ]
    }
}
